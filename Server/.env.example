# ============================================
# TaskFlow Server — Environment Configuration
# ============================================

# MongoDB Atlas connection string
# Replace <username>, <password>, <cluster> with your Atlas credentials
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/taskflow?retryWrites=true&w=majority

# JWT configuration
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS — frontend origin
CLIENT_URL=http://localhost:5173
